name: Validate Cask

on:
  workflow_dispatch:
  pull_request:
  push:
    branches:
      - main

jobs:
  validate:
    runs-on: macos-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v5

      - name: Fail on placeholder values
        shell: bash
        run: |
          if grep -R "__VERSION__\\|__SHA256__\\|__URL__" Casks; then
            echo "Cask still contains template placeholders."
            exit 1
          fi

      - name: Tap repository locally
        shell: bash
        run: brew tap --custom-local faker6996/tap .

      - name: Audit cask
        shell: bash
        run: brew audit --cask --strict --online ./Casks/ziply.rb
